            }
        },
        {
            "id": "http-tasks-001",
            "name": "Recuperer Taches du Jour",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                480,
                180
            ],
            "parameters": {
                "method": "GET",
                "url": "https://llcfsyjzxhmaalymkwwu.supabase.co/rest/v1/tasks",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
                            "value": "sb_publishable_eguo_16DBxvdcXUEFEDc8g_qKQH3BtB"
                        },
                        {
                            "name": "Authorization",
                            "value": "Bearer sb_publishable_eguo_16DBxvdcXUEFEDc8g_qKQH3BtB"
                        }
                    ]
                },
                "sendQuery": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "status",
                            "value": "eq.done"
                        },
                        {
                            "name": "select",
                            "value": "id,content,project_id,updated_at,status"

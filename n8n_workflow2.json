{
    "name": "ProjectOS - Resume Quotidien (Daily Summary)",
    "nodes": [
        {
            "id": "sched-001",
            "name": "Planifie - Chaque Jour 8h",
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1,
            "position": [
